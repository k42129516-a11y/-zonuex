local function createTeleportButton(parent, data, index)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 105, 0, 28)
    local row = math.floor((index - 1) / 4)
    local col = (index - 1) % 4
    btn.Position = UDim2.new(0, 5 + col * 110, 0, 35 + row * 35)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 75)
    btn.Text = data.name
    btn.TextColor3 = Color3.fromRGB(220, 220, 255)
    btn.TextSize = 12
    btn.Font = Enum.Font.GothamBold
    btn.Parent = parent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 5)
    btnCorner.Parent = btn
    
    btn.MouseButton1Click:Connect(function()
        local char = player.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                tweenService:Create(hrp, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {CFrame = CFrame.new(data.pos)}):Play()
                btn.BackgroundColor3 = Color3.fromRGB(0, 255, 100)
                task.wait(0.15)
                btn.BackgroundColor3 = Color3.fromRGB(45, 45, 75)
            end
        end
    end)
    
    return btn
end

