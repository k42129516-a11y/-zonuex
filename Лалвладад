local function createSection(parent, yPos, title, icon)
    local section = Instance.new("Frame")
    section.Size = UDim2.new(1, -20, 0, 80)
    section.Position = UDim2.new(0, 10, 0, yPos)
    section.BackgroundColor3 = Color3.fromRGB(25, 25, 45)
    section.BackgroundTransparency = 0.6
    section.BorderSizePixel = 0
    section.Parent = parent
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = section
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, -10, 0, 30)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = icon .. " " .. title
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 17
    label.Font = Enum.Font.GothamSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = section
    
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.new(0, 80, 0, 32)
    toggle.Position = UDim2.new(0.8, -90, 0, 4)
    toggle.BackgroundColor3 = Color3.fromRGB(50, 50, 80)
    toggle.Text = "OFF"
    toggle.TextColor3 = Color3.fromRGB(255, 100, 100)
    toggle.TextSize = 16
    toggle.Font = Enum.Font.GothamBold
    toggle.Parent = section
    
    local toggleCorner = Instance.new("UICorner")
    toggleCorner.CornerRadius = UDim.new(0, 6)
    toggleCorner.Parent = toggle
    
    local slider = Instance.new("TextBox")
    slider.Size = UDim2.new(0.5, -10, 0, 28)
    slider.Position = UDim2.new(0, 10, 0, 45)
    slider.BackgroundColor3 = Color3.fromRGB(35, 35, 55)
    slider.Text = "2.0x"
    slider.TextColor3 = Color3.fromRGB(200, 200, 255)
    slider.TextSize = 15
    slider.Font = Enum.Font.GothamBold
    slider.ClearTextOnFocus = false
    slider.Parent = section
    
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.CornerRadius = UDim.new(0, 6)
    sliderCorner.Parent = slider
    
    return section, toggle, slider
end

