-- ======================== MAIN LOOP ========================
runService.Heartbeat:Connect(function()
    local h = getHumanoid()
    if h then
        if speedEnabled then
            h.WalkSpeed = CONFIG.defaultSpeed * CONFIG.speedMultiplier
        else
            if h.WalkSpeed ~= CONFIG.defaultSpeed then
                h.WalkSpeed = CONFIG.defaultSpeed
            end
        end
        
        if jumpEnabled then
            h.JumpPower = CONFIG.defaultJump * CONFIG.jumpMultiplier
        else
            if h.JumpPower ~= CONFIG.defaultJump then
                h.JumpPower = CONFIG.defaultJump
            end
        end
    end
end)

