-- Roblox Script: +1 Keyboard Speed Boost
-- Paste into a LocalScript inside StarterPlayerScripts or StarterGui

local player = game.Players.LocalPlayer
local userInputService = game:GetService("UserInputService")
local runService = game:GetService("RunService")
local contextActionService = game:GetService("ContextActionService")

-- Configuration
local CONFIG = {
    boostMultiplier = 1.5,
    enableSprint = true,
    enableJumpBuff = true,
    enableStrafe = true,
    visualFeedback = true,
    keyBind = Enum.KeyCode.LeftShift
}

-- Speed variables
local originalWalkSpeed = 16
local originalJumpPower = 50
local boostedWalkSpeed = originalWalkSpeed * CONFIG.boostMultiplier
local boostedJumpPower = originalJumpPower * 1.3
local isBoosted = false

-- GUI setup
local screenGui = Instance.new("ScreenGui")
screenGui.Parent = player:WaitForChild("PlayerGui")

-- @zonuex watermark (launch text)
local watermark = Instance.new("TextLabel")
watermark.Size = UDim2.new(0, 300, 0, 50)
watermark.Position = UDim2.new(0.5, -150, 0.1, 0)
watermark.BackgroundTransparency = 1
watermark.Text = "@zonuex"
watermark.TextColor3 = Color3.fromRGB(0, 255, 200)
watermark.TextScaled = true
watermark.Font = Enum.Font.GothamBold
watermark.TextStrokeTransparency = 0.3
watermark.TextStrokeColor3 = Color3.fromRGB(0, 100, 200)
watermark.Parent = screenGui

-- Fade out animation for watermark
local tweenService = game:GetService("TweenService")
local fadeOut = tweenService:Create(watermark, TweenInfo.new(3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
    TextTransparency = 1
})
fadeOut:Play()

-- Speed label
local speedLabel = Instance.new("TextLabel")
speedLabel.Size = UDim2.new(0, 200, 0, 40)
speedLabel.Position = UDim2.new(0.5, -100, 0.9, 0)
speedLabel.BackgroundTransparency = 0.7
speedLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
speedLabel.TextScaled = true
speedLabel.Font = Enum.Font.GothamBold
speedLabel.Text = "Speed: NORMAL"
speedLabel.Visible = CONFIG.visualFeedback
speedLabel.Parent = screenGui

-- Small @zonuex footer
local footer = Instance.new("TextLabel")
footer.Size = UDim2.new(0, 100, 0, 20)
footer.Position = UDim2.new(1, -110, 1, -30)
footer.BackgroundTransparency = 1
footer.Text = "@zonuex"
footer.TextColor3 = Color3.fromRGB(100, 255, 200)
footer.TextSize = 14
footer.Font = Enum.Font.GothamBold
footer.TextXAlignment = Enum.TextXAlignment.Right
footer.Parent = screenGui

-- Character check
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")

local function applyBoost()
    if not humanoid or not character then return end
    
    if isBoosted then
        humanoid.WalkSpeed = boostedWalkSpeed
        humanoid.JumpPower = boostedJumpPower
        if CONFIG.visualFeedback then
            speedLabel.Text = "Speed: BOOSTED (" .. string.format("%.1f", boostedWalkSpeed) .. ")"
            speedLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        end
    else
        humanoid.WalkSpeed = originalWalkSpeed
        humanoid.JumpPower = originalJumpPower
        if CONFIG.visualFeedback then
            speedLabel.Text = "Speed: NORMAL"
            speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        end
    end
end

local function toggleBoost()
    isBoosted = not isBoosted
    applyBoost()
end

-- Keyboard input
userInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == CONFIG.keyBind then
        toggleBoost()
    end
    
    if input.KeyCode == Enum.KeyCode.LeftControl then
        if not isBoosted then
            isBoosted = true
            applyBoost()
        end
    end
end)

userInputService.InputEnded:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.LeftControl then
        if isBoosted then
            isBoosted = false
            applyBoost()
        end
    end
end)

local function checkMovement()
    if not humanoid or not character then return end
    
    local moveDirection = humanoid.MoveDirection
    local isMoving = moveDirection.Magnitude > 0.5
    
    if CONFIG.enableSprint and isMoving and not isBoosted then
        humanoid.WalkSpeed = originalWalkSpeed * 1.2
    elseif CONFIG.enableSprint and not isMoving and not isBoosted then
        humanoid.WalkSpeed = originalWalkSpeed
    end
    
    applyBoost()
end

local function applyStrafe()
    if not CONFIG.enableStrafe or not humanoid then return end
    
    local moveDirection = humanoid.MoveDirection
    local isMoving = moveDirection.Magnitude > 0.5
    
    if isMoving and isBoosted then
        humanoid.WalkSpeed = boostedWalkSpeed * 1.3
    elseif isMoving and not isBoosted then
        humanoid.WalkSpeed = originalWalkSpeed * 1.15
    end
end

runService.Heartbeat:Connect(function()
    if humanoid and character then
        checkMovement()
        if CONFIG.enableStrafe then
            applyStrafe()
        end
    end
end)

player.CharacterAdded:Connect(function(newCharacter)
    character = newCharacter
    humanoid = character:WaitForChild("Humanoid")
    originalWalkSpeed = humanoid.WalkSpeed or 16
    originalJumpPower = humanoid.JumpPower or 50
    boostedWalkSpeed = originalWalkSpeed * CONFIG.boostMultiplier
    boostedJumpPower = originalJumpPower * 1.3
    isBoosted = false
    applyBoost()
    
    -- Show @zonuex again on respawn
    watermark.TextTransparency = 0
    fadeOut:Play()
end)

local function onChatCommand(msg)
    if msg:lower() == "/boost" then
        toggleBoost()
        return true
    elseif msg:lower() == "/speed" then
        if humanoid then
            print("Current speed: " .. humanoid.WalkSpeed)
        end
        return true
    end
    return false
end

player.Chatted:Connect(onChatCommand)

-- Initial apply
applyBoost()

print("[+] @zonuex Keyboard Speed Boost loaded!")
print("[+] Press LeftShift to toggle boost")
print("[+] Type /boost to toggle via chat")
print("[+] Type /speed to check current speed")
